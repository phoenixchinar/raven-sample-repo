schema_version: raven.project/v1
project:
  id: raven-sample-repo
  name: raven_sample_repo
  type: sample
  description: Credit card transaction risk assessment sample for YAML-native RAVEN authoring.
source:
  mode: git_native
  format: yaml
  resource_root: raven
  control_dir: .raven
  default_compare_ref: origin/main
  source_of_truth:
    - raven.config
    - .raven/
    - raven/
  generated_or_local_only:
    - .raven/local/
authoring:
  allow_authoring_apis: false
  backward_compatibility: false
  retired_inputs_are_errors:
    - raven.yaml
    - .raven/config.json
    - json_resources
    - inline_variable_logic
    - name_only_refs
validation:
  command: null
  required_gates:
    - schema
    - graph
    - coverage
agents:
  grounding_checklist: .raven/agents/grounding-checklist.yaml
  backlog_routing: .raven/backlog/routing.yaml
  allowed_roots:
    - raven/
    - .raven/
    - raven.config
    - README.md
  forbidden_roots:
    - .git/
    - .env
    - .raven/local/
runtime_observation:
  enabled: false
  endpoints: []
github:
  enabled: true
  default_remote: https://github.com/phoenixchinar/raven-sample-repo.git
